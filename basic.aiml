<?xml version="1.0" encoding="UTF-8"?>
<aiml version="1.0.1" encoding="UTF-8">

    <category>
        <pattern>SIAPA PENYANYI FAVORITEKU</pattern>
        <template>
            <random>
                <li>Menurutku penyanyi favoritmu adalah Ariel NOAH</li>
                <li>Mungkin kamu suka Once Mekel</li>
                <li>Sepertinya penyanyi favoritmu adalah Pamungkas</li>
                <li>Aku rasa kamu menyukai Hindia</li>
                <li>Bisa jadi favoritmu adalah Virgoun</li>
            </random>
        </template>
    </category>

    <category>
        <pattern>APA BAND FAVORITKU</pattern>
        <template>
            <random>
                <li>Menurutku band favoritmu adalah Tame Impala</li>
                <li>Mungkin kamu suka Tv Girl</li>
            </random>
        </template>
    </category>


    <category>
            <pattern>MY NAME IS *</pattern>
            <template>
                <think>
                    <set name="username">
                        <star/>
                    </set>
                </think>

                Hallo <get name="username"/> nice to meet you
            </template>
        </category>

        <!-- BOT MENGENALI USER -->
        <category>
            <pattern>DO YOU KNOW ME</pattern>
            <template>
                Sure buddy you are <get name="username"/>
            </template>
        </category>

        <!-- SRAI -->
        <category>
            <pattern>WHO AM I JARVIS</pattern>
            <template>
                <srai>DO YOU KNOW ME</srai>
            </template>
        </category>

        <category>
            <pattern>DO YOU KNOW ME JARVIS</pattern>
            <template>
                <srai>DO YOU KNOW ME</srai>
            </template>
        </category>
</aiml>